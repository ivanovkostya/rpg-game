{
  "name": "rpg-game",
  "version": "1.0.0",
  "description": "RPG game",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "webpack --mode production",
    "dev": "webpack --mode development",
    "start": "webpack serve --mode development",
    "lint": "eslint src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivanovkostya/rpg-game.git"
  },
  "keywords": [
    "rpg",
    "game",
    "javascript",
    "webpack"
  ],
  "author": "Konstantin Ivanov",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ivanovkostya/rpg-game/issues"
  },
  "homepage": "https://github.com/ivanovkostya/rpg-game#readme",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "html-webpack-plugin": "^5.5.3",
    "mini-css-extract-plugin": "^2.7.6",
    "css-loader": "^6.8.1",
    "jest": "^29.6.0",
    "@types/jest": "^29.5.3"
  },
  "dependencies": {
    "core-js": "^3.49.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/js/index.js",
      "!src/js/game.js",
      "!src/js/Player.js",
      "!src/js/Warrior.js",
      "!src/js/Archer.js",
      "!src/js/Mage.js",
      "!src/js/Dwarf.js",
      "!src/js/Crossbowman.js",
      "!src/js/Demiurge.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}